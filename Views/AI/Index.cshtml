<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>QuerySense AI - Database Intelligence</title>

    <!-- Bootstrap 5 CSS only - no custom CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body class="bg-light d-flex flex-column min-vh-100">

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg bg-white shadow-sm py-3 mb-4">
        <div class="container-fluid px-4 px-lg-5">
            <a class="navbar-brand fw-bold text-primary d-flex align-items-center" href="#">
                <i class="bi bi-database-fill-gear fs-3 me-2"></i>
                <span class="text-dark">QuerySense</span> AI
            </a>
            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-3 py-2 border border-primary-subtle">
                <i class="bi bi-lightning-charge-fill text-warning me-1"></i> Powered by AI
            </span>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-grow-1 container pb-5">
        
        <!-- Hero Section -->
        <div class="row justify-content-center mb-5 text-center pt-3">
            <div class="col-lg-8 col-xl-7">
                <h1 class="display-4 fw-bolder text-dark mb-3">
                    Talk to your <span class="text-primary">Database</span>
                </h1>
                <p class="lead text-secondary fw-normal">
                    Transform plain English questions into optimized SQL queries instantly. No coding required.
                </p>
            </div>
        </div>

        <!-- Search Input Card -->
        <div class="row justify-content-center mb-5">
            <div class="col-lg-8 col-xl-7">
                <div class="card shadow border-0 rounded-4 bg-white">
                    <div class="card-body p-2">
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-transparent border-0 text-primary px-3">
                                <i class="bi bi-stars fs-4"></i>
                            </span>
                            <input type="text" id="question" class="form-control border-0 shadow-none px-2 fs-5 text-dark" placeholder="e.g., Show me the top 5 customers by revenue..." />
                            <button class="btn btn-primary rounded-4 px-4 px-md-5 fw-bold shadow-sm d-flex align-items-center" onclick="ask()">
                                Generate <i class="bi bi-arrow-right-short fs-4 ms-1"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="mt-3 text-center">
                    <div class="d-inline-flex align-items-center bg-white shadow-sm rounded-pill px-3 py-2 border">
                        <i class="bi bi-lightbulb-fill text-warning me-2"></i>
                        <span class="text-muted small"><strong>Try:</strong> "Show me total employees by department"</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Loading Spinner -->
        <div id="loading" style="display: none;">
            <div class="row justify-content-center my-5 pb-4">
                <div class="col-auto text-center">
                    <div class="spinner-border text-primary mb-3" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">Analyzing database schema...</h5>
                    <p class="text-muted mb-0">Crafting the perfect SQL query for you</p>
                </div>
            </div>
        </div>

        <!-- Results Section -->
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-9">
                
                <!-- SQL Card -->
                <div class="card shadow-sm border-0 rounded-4 mb-4 overflow-hidden">
                    <div class="card-header bg-white border-bottom border-light pt-4 pb-3 px-4 d-flex align-items-center justify-content-between">
                        <h6 class="mb-0 fw-bold text-secondary text-uppercase">
                            <i class="bi bi-terminal text-primary me-2"></i>Generated SQL
                        </h6>
                    </div>
                    <div class="card-body p-0 bg-dark">
                        <pre id="sqlBox" class="text-info m-0 p-4 fs-6 overflow-auto"></pre>
                    </div>
                </div>

                <!-- Results Card -->
                <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                    <div class="card-header bg-white border-bottom border-light pt-4 pb-3 px-4 d-flex align-items-center justify-content-between">
                        <h6 class="mb-0 fw-bold text-secondary text-uppercase">
                            <i class="bi bi-table text-success me-2"></i>Query Results
                        </h6>
                        <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">
                            <i class="bi bi-check-circle-fill me-1"></i> Success
                        </span>
                    </div>
                    <div class="card-body p-0">
                        <div id="tableContainer" class="table-responsive">
                            <!-- Table generated by JS -->
                        </div>
                    </div>
                </div>
                
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-white py-4 mt-auto border-top">
        <div class="container text-center">
            <p class="text-muted mb-0 small">
                <i class="bi bi-code-slash me-1"></i> Built with <i class="bi bi-heart-fill text-danger mx-1"></i> using Bootstrap 5
            </p>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function ask() {
            var question = $("#question").val();
            $("#loading").show();
            $("#sqlBox").html("");
            $("#tableContainer").html("");

            $.ajax({
                url: "http://127.0.0.1:5000/ask",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify({
                    question: question
                }),
                success: function (response) {
                    $("#loading").hide();
                    $("#sqlBox").text(response.sql);

                    buildTable
                        (
                            response.columns,
                            response.data
                        );
                },
                error: function () {
                    $("#loading").hide();

                    alert("Error while calling AI API");
                }
                
            });
        }

        function buildTable(columns, data) {
            var html = "<table class='table table bordered'>";

            html += "<thead><tr>";

            for (var i = 0; i < columns.length; i++) {
                html += "<th>" + columns[i] + "</th>";

            }

            html += "</thead></tr>"
            html += "<tbody>"
            for (var r = 0; r < data.length; r++) {
                html += "<tr>";
                for (var c = 0; c < data[r].length; c++) {
                    html += "<td>" + data[r][c] + "</td>";
                }
                html += "</tr>";

            }
            html += "</tbody></table>";
            $("#tableContainer").html(html);
        }
    </script>

</body>
</html>