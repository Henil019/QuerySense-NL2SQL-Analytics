@model QuerySense.Models.DashboardViewModel
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<div class="container mt-4">
    <h3 class="mb-4 text-secondary fw-bold">
        <i class="bi bi-speedometer2 me-2"></i>QuerySense Dashboard
    </h3>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 border-0 border-start border-primary border-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase mb-1">Total Revenue</h6>
                        <h3 class="mb-0 fw-bold">₹ @Model.TotalRevenue</h3>
                    </div>
                    <i class="bi bi-cash-stack fs-1 text-primary opacity-50"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 border-0 border-start border-success border-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase mb-1">Total Orders</h6>
                        <h3 class="mb-0 fw-bold">@Model.TotalOrders</h3>
                    </div>
                    <i class="bi bi-cart-check fs-1 text-success opacity-50"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 border-0 border-start border-info border-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase mb-1">Total Customers</h6>
                        <h3 class="mb-0 fw-bold">@Model.TotalCustomers</h3>
                    </div>
                    <i class="bi bi-people fs-1 text-info opacity-50"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 border-0 border-start border-warning border-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase mb-1">Avg Order Value</h6>
                        <h3 class="mb-0 fw-bold">₹ @Model.AverageOrderValue</h3>
                    </div>
                    <i class="bi bi-graph-up fs-1 text-warning opacity-50"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 border-0 border-start border-danger border-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div class="me-3">
                        <h6 class="text-muted text-uppercase mb-1">Top Product</h6>
                        <h4 class="mb-0 fw-bold text-truncate" style="max-width: 200px;">@Model.TopProduct</h4>
                    </div>
                    <i class="bi bi-box-seam fs-1 text-danger opacity-50"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100 border-0 border-start border-secondary border-4">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted text-uppercase mb-1">Top Category</h6>
                        <h4 class="mb-0 fw-bold">@Model.TopCategory</h4>
                    </div>
                    <i class="bi bi-tags fs-1 text-secondary opacity-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow mt-4">
    <div class="card-body">
        <h4>Monthly Revenue Trend</h4>

        <canvas id="revenueChart"></canvas>
    </div>
</div>
<script>

var months = [
@Html.Raw(string.Join(",",
Model.RevenueTrendData.Select(x =>
"'" + x.Month + "'")))
];

var revenue = [
@Html.Raw(string.Join(",",
Model.RevenueTrendData.Select(x =>
x.Revenue)))
];

var ctx =
document.getElementById('revenueChart');

new Chart(ctx, {

    type: 'line',

    data: {

        labels: months,

        datasets: [{

            label: 'Revenue',

            data: revenue

        }]
    }
});

</script>